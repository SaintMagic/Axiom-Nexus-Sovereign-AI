{
    "name": "n8n-nodes-local-ai-manager",
    "version": "0.1.0",
    "description": "Custom n8n node to interact with local Ollama instance",
    "keywords": [
        "n8n-community-node-package"
    ],
    "license": "MIT",
    "homepage": "https://n8n.io",
    "author": {
        "name": "Local AI Master",
        "email": "demo@example.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/n8n-io/n8n-nodes-local-ai-manager.git"
    },
    "main": "dist/LocalAiManager.node.js",
    "scripts": {
        "build": "tsc && powershell -Command \"Copy-Item -Path 'nodes/LocalAiManager/robot.svg' -Destination 'dist/' -Force\""
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "nodes": [
            "dist/LocalAiManager.node.js"
        ]
    },
    "devDependencies": {
        "n8n-workflow": "^1.60.0",
        "typescript": "^5.0.0"
    },
    "peerDependencies": {
        "n8n-workflow": "^1.60.0"
    }
}
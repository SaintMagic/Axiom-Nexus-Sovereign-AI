{
  "version": "1.0.0",
  "functions": [
    {
      "name": "write_file",
      "category": "file_edit",
      "description": "Create or overwrite file content.",
      "when_to_use": [
        "User asks to create a file with text",
        "User asks to overwrite file content"
      ],
      "inputs": {
        "target_file": "string",
        "content": "string",
        "write_mode": "overwrite|append"
      },
      "required_inputs": [
        "target_file"
      ],
      "forbidden_cases": [
        "target file unresolved and command is not explicit create intent"
      ],
      "implementation": "functions/write_file.json",
      "deterministic": true,
      "risk": "medium",
      "tags": [
        "file",
        "write",
        "create",
        "overwrite"
      ],
      "enabled": true,
      "experimental": false,
      "version": "1.0"
    },
    {

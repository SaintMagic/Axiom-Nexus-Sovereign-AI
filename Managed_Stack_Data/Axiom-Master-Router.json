[
    {
        "id": "dTzRbVa8bRBZTZ6O",
        "name": "Axiom Master Router",
        "versionId": "db8e3bb3-a5f1-460d-a342-fd82531636c2",
        "nodes": [
            {
                "id": "node-webhook",
                "name": "Webhook Input",
                "type": "n8n-nodes-base.webhook",
                "typeVersion": 1,
                "position": [
                    0,
                    200
                ],
                "parameters": {
                    "httpMethod": "POST",
                    "path": "openclaw-exec",
                    "responseMode": "onReceived"
                }
            },
            {
                "id": "node-extract",
                "name": "Extract Input",
                "type": "n8n-nodes-base.code",
                "typeVersion": 1,
                "position": [
                    200,
                    200
                ],
                "parameters": {
                    "mode": "runOnceForEachItem",
                    "jsCode": "return { json: { mode: $input.item.json.body.mode || 'chat', content: $input.item.json.body.content } };"
                }
            },
            {
                "id": "node-switch-mode",
                "name": "Mode Router",
                "type": "n8n-nodes-base.switch",
                "typeVersion": 3.4,
                "position": [
                    400,
                    200
                ],
                "parameters": {
                    "mode": "rules",
                    "rules": {
                        "values": [
                            {
                                "renameOutput": false,
                                "outputIndex": 0,
                                "conditions": {
                                    "options": {
                                        "caseSensitive": true,
                                        "leftValue": "",
                                        "typeValidation": "strict",
                                        "version": 3
                                    },
                                    "conditions": [
                                        {
                                            "leftValue": "={{ $json.mode }}",
                                            "rightValue": "chat",
                                            "operator": {
                                                "type": "string",
                                                "operation": "equals"
                                            },
                                            "id": "cond-1"
                                        }
                                    ],
                                    "combinator": "and"
                                }
                            },
                            {
                                "renameOutput": false,
                                "outputIndex": 1,
                                "conditions": {
                                    "options": {
                                        "caseSensitive": true,
                                        "leftValue": "",
                                        "typeValidation": "strict",
                                        "version": 3
                                    },
                                    "conditions": [
                                        {
                                            "leftValue": "={{ $json.mode }}",
                                            "rightValue": "tool",
                                            "operator": {
                                                "type": "string",
                                                "operation": "equals"
                                            },
                                            "id": "cond-2"
                                        }
                                    ],
                                    "combinator": "and"
                                }
                            },
                            {
                                "renameOutput": false,
                                "outputIndex": 2,
                                "conditions": {
                                    "options": {
                                        "caseSensitive": true,
                                        "leftValue": "",
                                        "typeValidation": "strict",
                                        "version": 3
                                    },
                                    "conditions": [
                                        {
                                            "leftValue": "={{ $json.mode }}",
                                            "rightValue": "task",
                                            "operator": {
                                                "type": "string",
                                                "operation": "equals"
                                            },
                                            "id": "cond-3"
                                        }
                                    ],
                                    "combinator": "and"
                                }
                            }
                        ]
                    }
                }
            },
            {
                "id": "node-tool-parse",
                "name": "Ollama Tool Parse",
                "type": "localAiManager",
                "typeVersion": 1,
                "position": [
                    600,
                    200
                ],
                "parameters": {
                    "connectionType": "local",
                    "modelName": "llama3.2",
                    "systemDirective": "Convert the user's tool request into STRICT JSON matching exactly this schema:\n{\n  \"action\": \"write_file\" | \"read_file\" | \"list_directory\",\n  \"path\": \"THE ABSOLUTE PATH OR FILENAME\",\n  \"content\": \"THE DATA TO WRITE (if write_file)\"\n}\nRespond ONLY with raw JSON. No markdown backticks. No explanation.",
                    "userInput": "={{ $node[\"Extract Input\"].json.content }}"
                }
            },
            {
                "id": "node-parse-json",
                "name": "Parse JSON",
                "type": "n8n-nodes-base.code",
                "typeVersion": 1,
                "position": [
                    800,
                    200
                ],
                "parameters": {
                    "jsCode": "try {\n  const parsed = JSON.parse($input.item.json.response);\n  return { json: parsed };\n} catch(e) {\n  return { json: { action: 'error', message: 'Failed to parse JSON' } };\n}"
                }
            },
            {
                "id": "node-switch-tool",
                "name": "Tool Hub",
                "type": "n8n-nodes-base.switch",
                "typeVersion": 3.4,
                "position": [
                    1000,
                    200
                ],
                "parameters": {
                    "mode": "rules",
                    "options": {
                        "fallbackOutput": 3
                    },
                    "rules": {
                        "values": [
                            {
                                "renameOutput": false,
                                "outputIndex": 0,
                                "conditions": {
                                    "options": {
                                        "caseSensitive": true,
                                        "leftValue": "",
                                        "typeValidation": "strict",
                                        "version": 3
                                    },
                                    "conditions": [
                                        {
                                            "leftValue": "={{ $json.action }}",
                                            "rightValue": "write_file",
                                            "operator": {
                                                "type": "string",
                                                "operation": "equals"
                                            },
                                            "id": "cond-a"
                                        }
                                    ],
                                    "combinator": "and"
                                }
                            },
                            {
                                "renameOutput": false,
                                "outputIndex": 1,
                                "conditions": {
                                    "options": {
                                        "caseSensitive": true,
                                        "leftValue": "",
                                        "typeValidation": "strict",
                                        "version": 3
                                    },
                                    "conditions": [
                                        {
                                            "leftValue": "={{ $json.action }}",
                                            "rightValue": "read_file",
                                            "operator": {
                                                "type": "string",
                                                "operation": "equals"
                                            },
                                            "id": "cond-b"
                                        }
                                    ],
                                    "combinator": "and"
                                }
                            },
                            {
                                "renameOutput": false,
                                "outputIndex": 2,
                                "conditions": {
                                    "options": {
                                        "caseSensitive": true,
                                        "leftValue": "",
                                        "typeValidation": "strict",
                                        "version": 3
                                    },
                                    "conditions": [
                                        {
                                            "leftValue": "={{ $json.action }}",
                                            "rightValue": "list_directory",
                                            "operator": {
                                                "type": "string",
                                                "operation": "equals"
                                            },
                                            "id": "cond-c"
                                        }
                                    ],
                                    "combinator": "and"
                                }
                            }
                        ]
                    }
                }
            },
            {
                "id": "node-tool-write",
                "name": "Tool: Write File",
                "type": "n8n-nodes-base.readWriteFile",
                "typeVersion": 1,
                "position": [
                    1200,
                    100
                ],
                "parameters": {
                    "operation": "write",
                    "fileName": "={{$json.path}}",
                    "dataPropertyName": "={{$json.content}}"
                }
            },
            {
                "id": "node-tool-read",
                "name": "Tool: Read File",
                "type": "n8n-nodes-base.readWriteFile",
                "typeVersion": 1,
                "position": [
                    1200,
                    200
                ],
                "parameters": {
                    "operation": "read",
                    "fileName": "={{$json.path}}"
                }
            },
            {
                "id": "node-tool-list",
                "name": "Tool: List Directory",
                "type": "n8n-nodes-base.readWriteFile",
                "typeVersion": 1,
                "position": [
                    1200,
                    300
                ],
                "parameters": {
                    "operation": "list",
                    "path": "={{$json.path}}"
                }
            },
            {
                "id": "node-tool-error",
                "name": "Error Tool Format",
                "type": "n8n-nodes-base.set",
                "typeVersion": 1,
                "position": [
                    1200,
                    400
                ],
                "parameters": {
                    "keepOnlySet": true,
                    "values": {
                        "string": [
                            {
                                "name": "response",
                                "value": "Unknown or invalid action requested."
                            }
                        ]
                    }
                }
            },
            {
                "id": "node-format-write",
                "name": "Format Write Output",
                "type": "n8n-nodes-base.set",
                "typeVersion": 1,
                "position": [
                    1400,
                    100
                ],
                "parameters": {
                    "keepOnlySet": true,
                    "values": {
                        "string": [
                            {
                                "name": "response",
                                "value": "=I have successfully written the file to {{$node[\"Parse JSON\"].json.path}}."
                            }
                        ]
                    }
                }
            },
            {
                "id": "node-format-read",
                "name": "Format Read Output",
                "type": "n8n-nodes-base.set",
                "typeVersion": 1,
                "position": [
                    1400,
                    200
                ],
                "parameters": {
                    "keepOnlySet": true,
                    "values": {
                        "string": [
                            {
                                "name": "response",
                                "value": "=File Contents:\n\n{{$json.data}}"
                            }
                        ]
                    }
                }
            },
            {
                "id": "node-format-list",
                "name": "Format List Output",
                "type": "n8n-nodes-base.set",
                "typeVersion": 1,
                "position": [
                    1400,
                    300
                ],
                "parameters": {
                    "keepOnlySet": true,
                    "values": {
                        "string": [
                            {
                                "name": "response",
                                "value": "=Directory Contents:\n\n{{JSON.stringify($input.all().map(i => i.json.name), null, 2)}}"
                            }
                        ]
                    }
                }
            },
            {
                "id": "node-ollama-task",
                "name": "Ollama Task Mode",
                "type": "localAiManager",
                "typeVersion": 1,
                "position": [
                    600,
                    500
                ],
                "parameters": {
                    "connectionType": "local",
                    "modelName": "llama3.2",
                    "systemDirective": "You are OpenClaw, processing an automation task. The user is outlining a multi-step objective for you.",
                    "userInput": "={{ $node[\"Extract Input\"].json.content }}"
                }
            },
            {
                "id": "node-format-task",
                "name": "Format Task Output",
                "type": "n8n-nodes-base.set",
                "typeVersion": 1,
                "position": [
                    800,
                    500
                ],
                "parameters": {
                    "keepOnlySet": true,
                    "values": {
                        "string": [
                            {
                                "name": "response",
                                "value": "={{$node[\"Ollama Task Mode\"].json.response}}"
                            }
                        ]
                    }
                }
            },
            {
                "id": "node-chat",
                "name": "Ollama Chat",
                "type": "localAiManager",
                "typeVersion": 1,
                "position": [
                    600,
                    0
                ],
                "parameters": {
                    "connectionType": "local",
                    "modelName": "llama3.2",
                    "systemDirective": "You are OpenClaw, the Sovereign AI Engine for Axiom Nexus. Be helpful and concise.",
                    "userInput": "={{ $node[\"Extract Input\"].json.content }}"
                }
            },
            {
                "id": "node-format-chat",
                "name": "Format Chat Output",
                "type": "n8n-nodes-base.set",
                "typeVersion": 1,
                "position": [
                    800,
                    0
                ],
                "parameters": {
                    "keepOnlySet": true,
                    "values": {
                        "string": [
                            {
                                "name": "response",
                                "value": "={{$node[\"Ollama Chat\"].json.response}}"
                            }
                        ]
                    }
                }
            },
            {
                "id": "node-respond",
                "name": "Final Response (Mock)",
                "type": "n8n-nodes-base.respondToWebhook",
                "typeVersion": 1,
                "position": [
                    1800,
                    200
                ],
                "parameters": {
                    "respondWith": "allIncomingItems"
                }
            }
        ],

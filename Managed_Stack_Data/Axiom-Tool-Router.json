        {
            "parameters": {
                "rules": {
                    "values": [
                        {
                            "conditions": {
                                "options": {
                                    "caseSensitive": true,
                                    "leftValue": "={{$json.body.action}}",
                                    "type": "string"
                                },
                                "conditions": [
                                    {
                                        "leftValue": "={{$json.body.action}}",
                                        "operator": "equal",
                                        "rightValue": "write_file"
                                    }
                                ],
                                "combinator": "and"
                            },
                            "outputIndex": 0
                        },
                        {
                            "conditions": {
                                "options": {
                                    "caseSensitive": true,
                                    "leftValue": "={{$json.body.action}}",
                                    "type": "string"
                                },
                                "conditions": [
                                    {
                                        "leftValue": "={{$json.body.action}}",
                                        "operator": "equal",
                                        "rightValue": "read_file"
                                    }
                                ],
                                "combinator": "and"
                            },
                            "outputIndex": 1
                        },
                        {
                            "conditions": {
                                "options": {
                                    "caseSensitive": true,
                                    "leftValue": "={{$json.body.action}}",
                                    "type": "string"
                                },
                                "conditions": [

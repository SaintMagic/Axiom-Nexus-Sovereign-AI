                            "outputIndex": 2
                        },
                        {
                            "conditions": {
                                "options": {
                                    "caseSensitive": true,
                                    "leftValue": "={{$json.body.action}}",
                                    "type": "string"
                                },
                                "conditions": [
                                    {
                                        "leftValue": "={{$json.body.action}}",
                                        "operator": "equal",
                                        "rightValue": "invoice_process"
                                    }
                                ],
                                "combinator": "and"
                            },
                            "outputIndex": 3
                        },
                        {
                            "conditions": {
                                "options": {
                                    "caseSensitive": true,
                                    "leftValue": "={{$json.body.action}}",
                                    "type": "string"
                                },
                                "conditions": [
                                    {
                                        "leftValue": "={{$json.body.action}}",
                                        "operator": "equal",
                                        "rightValue": "auto_filer"
                                    }
                                ],
                                "combinator": "and"
                            },
                            "outputIndex": 4
                        }
                    ]
                },
                "options": {}
